# .env.example
"""
VLM4GIS Environment Variables Example
"""
# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Model Configuration
MODEL_PATH=/path/to/your/model/checkpoint
MODEL_NAME=qwen-vl

# GPU Configuration
GPU_MEMORY_UTIL=0.6
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=256
ENABLE_PREFIX_CACHING=true

# Session Configuration
SESSION_TEMP_DIR=/tmp/vlm4gis
SESSION_MAX_AGE_HOURS=24
MAX_IMAGE_SIZE=4096

# Task Configuration
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_TOKENS=512
MAX_CONCURRENT_VALIDATIONS=5

# API Configuration
CORS_ORIGINS=*
API_KEY_REQUIRED=false
# API_KEYS=key1,key2,key3

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/var/log/vlm4gis.log

# ===================================